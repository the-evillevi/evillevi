---
const columns = [
  {
    title: "System",
    links: [
      { label: "Components", href: "#components" },
      { label: "Playground", href: "#playground" },
      { label: "Docs", href: "#docs" },
    ],
  },
  {
    title: "Tokens",
    links: [
      { label: "Color", href: "#tokens" },
      { label: "3D Decor", href: "#three-decor" },
      { label: "Back to top", href: "#top" },
    ],
  },
  {
    title: "Garden",
    links: [
      { label: "Blog", href: "/blog" },
      { label: "Docs", href: "/docs" },
      { label: "Tags", href: "/tags" },
    ],
  },
];
---

<footer
  class="border-t-4 border-[var(--nb-ink)] bg-[var(--nb-surface)] px-4 py-10 text-[var(--nb-text)] md:px-6"
>
  <div class="mx-auto grid max-w-7xl gap-8 md:grid-cols-[1.2fr_2fr]">
    <div>
      <p class="mb-3 text-3xl font-black uppercase">NB.CC</p>
      <p class="max-w-md text-sm leading-6 font-bold text-[var(--nb-muted)]">
        Thick borders, louder states, calmer tokens. Built as an Astro showcase for
        Catppuccin-flavored neobrutalism.
      </p>
    </div>
    <div class="grid gap-4 sm:grid-cols-3">
      {
        columns.map((column) => (
          <div class="border-4 border-[var(--nb-ink)] bg-[var(--nb-base)] p-4 shadow-[4px_4px_0_0_var(--nb-ink)]">
            <h2 class="mb-3 text-sm font-black uppercase">{column.title}</h2>
            <ul class="space-y-2">
              {column.links.map((link) => (
                <li>
                  <a
                    class="text-sm font-bold text-[var(--nb-muted)] underline decoration-4 underline-offset-4 transition-all duration-200 ease-[var(--nb-ease)] hover:text-[var(--nb-peach)] focus-visible:outline focus-visible:outline-4 focus-visible:outline-offset-4 focus-visible:outline-[var(--nb-blue)]"
                    href={link.href}
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</footer>
