---
import { render } from "astro:content";
import ContentLayout from "@/layouts/ContentLayout.astro";
import { getBacklinks, getOutgoingLinks } from "@/utils/links";
import { getBlogPosts, getDocsEntries } from "@/utils/content";

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  const docs = await getDocsEntries();
  const entries = [...posts, ...docs];

  return posts.map((entry) => ({
    params: { id: entry.id },
    props: {
      entry,
      entries,
      backlinks: getBacklinks(entry, entries),
      outgoingLinks: getOutgoingLinks(entry, entries),
    },
  }));
}

const { entry, backlinks, outgoingLinks } = Astro.props;
const { Content, headings } = await render(entry);
---

<ContentLayout {entry} {headings} {backlinks} {outgoingLinks}>
  <Content />
</ContentLayout>
