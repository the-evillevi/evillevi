---
import PostCard from "@/components/blog/PostCard.astro";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { getBlogPosts } from "@/utils/content";

const posts = await getBlogPosts();
---

<SiteLayout title="Blog" description="All blog posts">
  <section class="mx-auto max-w-7xl px-4 py-10 md:px-6">
    <header class="nb-shadow mb-8 border-4 border-[var(--nb-ink)] bg-[var(--nb-surface)] p-6">
      <h1 class="text-6xl font-black uppercase md:text-8xl">Blog</h1>
      <p class="mt-3 max-w-2xl text-lg font-bold text-[var(--nb-muted)]">
        Field notes, experiments, and connected essays.
      </p>
    </header>
    <div class="grid gap-5 md:grid-cols-2">
      {posts.map((entry) => <PostCard {entry} />)}
    </div>
  </section>
</SiteLayout>
