---
import { AffogatoApp } from "@/components/affogato/AffogatoApp";
import SiteLayout from "@/layouts/SiteLayout.astro";

const description =
  "Affogato is a local-first Pomodoro timer with tasks, stats, bean rewards, and cozy voxel placeholders.";
---

<SiteLayout title="Affogato - Voxel Pomodoro Timer" description={description}>
  <AffogatoApp client:load />
  <section class="mx-auto grid max-w-5xl gap-8 px-4 pt-4 pb-16 sm:px-6 lg:grid-cols-3 lg:px-8">
    <article class="nb-panel p-5">
      <h2 class="text-xl font-black tracking-normal uppercase">What is Affogato?</h2>
      <p class="mt-3 text-sm leading-6 font-bold text-[var(--nb-muted)]">
        Affogato is a focused work timer that pairs Pomodoro sessions with simple task tracking,
        local stats, and a bean balance that grows while you stay on the clock.
      </p>
    </article>
    <article class="nb-panel p-5">
      <h2 class="text-xl font-black tracking-normal uppercase">How Pomodoro Works</h2>
      <p class="mt-3 text-sm leading-6 font-bold text-[var(--nb-muted)]">
        Choose one task, work for a focused interval, take a short break, and repeat. After a few
        rounds, take a longer break before starting the next cycle.
      </p>
    </article>
    <article class="nb-panel p-5">
      <h2 class="text-xl font-black tracking-normal uppercase">Voxel Placeholders</h2>
      <p class="mt-3 text-sm leading-6 font-bold text-[var(--nb-muted)]">
        The current 3D scenes are intentionally simple cube-based placeholders. They reserve the
        exact island slots where original voxel assets will land later.
      </p>
    </article>
  </section>
</SiteLayout>
