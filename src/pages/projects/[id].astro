---
import { getCollection } from "astro:content";
import SiteLayout from "@/layouts/SiteLayout.astro";

/* Live-demo host for projects without their own app page. Static routes
 * (e.g. projects/affogato/index.astro) win over this dynamic route, so
 * only entries flagged demoPage generate here. */
export async function getStaticPaths() {
  const projects = await getCollection("projects", ({ data }) => data.demoPage);
  return projects.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { title, valueProp, repoUrl } = entry.data;
---

<SiteLayout title={title} description={entry.data.description}>
  <section class="border-b-4 border-[var(--nb-ink)] bg-[var(--nb-base)] px-4 py-8 md:px-6">
    <div class="mx-auto flex max-w-7xl flex-wrap items-end justify-between gap-4">
      <div>
        <h1 class="text-4xl font-black uppercase md:text-6xl">{title}</h1>
        <p class="mt-2 max-w-2xl text-base font-bold text-[var(--nb-muted)]">{valueProp}</p>
      </div>
      <div class="flex flex-wrap gap-2">
        {
          repoUrl ? (
            <a class="nb-action bg-[var(--nb-base)] px-4 py-3 text-sm text-[var(--nb-text)]" href={repoUrl}>
              GitHub Repository
            </a>
          ) : (
            <span
              class="cursor-not-allowed border-4 border-[var(--nb-ink)] bg-[var(--nb-surface)] px-4 py-3 text-sm font-black text-[var(--nb-muted)] uppercase opacity-70"
              title="Repository link pending"
            >
              [GITHUB_REPO_URL]
            </span>
          )
        }
        <a class="nb-action bg-[var(--nb-blue)] px-4 py-3 text-sm" href="/projects">
          Read the deep dive &rarr;
        </a>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-10 md:px-6">
    <div
      class="nb-shadow grid min-h-[28rem] place-items-center border-4 border-dashed border-[var(--nb-ink)] bg-[repeating-linear-gradient(45deg,var(--nb-surface)_0_16px,var(--nb-base)_16px_32px)] p-8 text-center"
    >
      <div class="max-w-xl border-4 border-[var(--nb-ink)] bg-[var(--nb-base)] p-6">
        <p class="text-lg font-black uppercase">Live Demo Area</p>
        <p class="mt-3 text-sm leading-6 font-bold text-[var(--nb-muted)]">
          [LIVE_DEMO: the main interactive application/canvas interface renders here — replace this
          placeholder with the project's island, e.g. &lt;ProjectApp client:load /&gt;]
        </p>
      </div>
    </div>
  </section>
</SiteLayout>
