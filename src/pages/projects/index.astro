---
import "reveal.js/reveal.css";
import { getCollection, render } from "astro:content";
import SiteLayout from "@/layouts/SiteLayout.astro";

const projects = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);
const rendered = await Promise.all(
  projects.map(async (entry) => ({ entry, Content: (await render(entry)).Content })),
);
const padded = (value: number) => String(value).padStart(2, "0");

const description =
  "A 2D presentation of selected work: navigate left/right to explore projects, down to inspect the technical deep dives.";

// Deck chrome, expressed with the site's --nb-* tokens as Tailwind arbitrary
// values so the markup stays the single source of truth (no bespoke CSS).
const chip =
  "inline-block border-2 border-[var(--nb-ink)] px-3 py-1.5 text-xs font-black tracking-wide uppercase text-[var(--nb-button-text)] shadow-[2px_2px_0_0_var(--nb-ink)]";
const techColors = [
  "bg-[var(--nb-yellow)]",
  "bg-[var(--nb-teal)]",
  "bg-[var(--nb-pink)]",
  "bg-[var(--nb-green)]",
  "bg-[var(--nb-lavender)]",
];
---

<SiteLayout title="Projects" description={description}>
  <section class="border-b-4 border-[var(--nb-ink)] bg-[var(--nb-base)]">
    <div id="projects-deck" class="reveal" tabindex="0" aria-label="Projects presentation">
      <div class="slides">
        <!-- ============================================================
             SLIDE 1 — INTRO (no vertical children)
             ============================================================ -->
        <section>
          <span class={`${chip} mb-4 bg-[var(--nb-pink)]`}>Portfolio · 2026</span>
          <h1>Selected Work</h1>
          <p class="tagline">A guided tour of things I've designed, built, and shipped.</p>
          <div class="my-6 flex flex-wrap justify-center gap-3">
            <span class={`${chip} bg-[var(--nb-teal)]`}>→ Left / Right · Explore projects</span>
            <span class={`${chip} bg-[var(--nb-green)]`}>↓ Down · Inspect the deep dive</span>
            <span class={`${chip} bg-[var(--nb-pink)]`}>ESC · Bird's-eye overview</span>
          </div>
          <p class="font-bold text-[var(--nb-muted)]">Use the arrows, your keyboard, or swipe.</p>
        </section>

        <!-- ============================================================
             ONE COLUMN PER PROJECT — overview card (↓ deep dive renders
             the project's MDX body). Driven by the content collection.
             ============================================================ -->
        {
          rendered.map(({ entry, Content }, index) => (
            <section>
              {/* Overview card */}
              <section class="relative">
                <span class={`${chip} mb-4 bg-[var(--nb-pink)]`}>Project {padded(index + 1)}</span>
                <h2>{entry.data.title}</h2>
                <p class="tagline">{entry.data.valueProp}</p>
                <div class="my-6 flex flex-wrap justify-center gap-2">
                  {entry.data.tech.map((item, techIndex) => (
                    <span class={`${chip} ${techColors[techIndex % techColors.length]}`}>
                      {item}
                    </span>
                  ))}
                </div>
                <div class="my-6 flex flex-wrap justify-center gap-3">
                  <a
                    class="nb-action px-6 py-3 text-base"
                    href={entry.data.liveUrl}
                    target="_blank"
                    rel="noopener"
                  >
                    Live App
                  </a>
                  {entry.data.repoUrl ? (
                    <a
                      class="nb-action bg-[var(--nb-base)] px-6 py-3 text-base text-[var(--nb-text)]"
                      href={entry.data.repoUrl}
                      target="_blank"
                      rel="noopener"
                    >
                      GitHub
                    </a>
                  ) : (
                    <span
                      class="cursor-not-allowed border-4 border-[var(--nb-ink)] bg-[var(--nb-surface)] px-6 py-3 text-base font-black text-[var(--nb-muted)] uppercase opacity-70"
                      title="Repository link pending"
                    >
                      [GITHUB_REPO_URL]
                    </span>
                  )}
                </div>
                <span
                  class="absolute bottom-[-130px] left-1/2 inline-flex -translate-x-1/2 animate-bounce items-center gap-2.5 border-4 border-[var(--nb-ink)] bg-[var(--nb-green)] px-4 py-2.5 text-[15px] font-black tracking-wide whitespace-nowrap text-[var(--nb-button-text)] uppercase shadow-[4px_4px_0_0_var(--nb-ink)] motion-reduce:animate-none"
                  aria-hidden="true"
                >
                  <span class="text-[22px] leading-none">↓</span> Deep dive available
                </span>
              </section>

              {/* Deep dive — the project's MDX body, scrollable inside the slide */}
              <section>
                <div class="nb-card mx-auto max-h-[640px] w-full max-w-3xl overflow-y-auto p-6 text-left md:p-8">
                  <p class="text-sm font-black tracking-wider text-[var(--nb-muted)] uppercase">
                    {entry.data.title} · Deep dive
                  </p>
                  <div class="nb-prose mt-3 text-base">
                    <Content />
                  </div>
                </div>
              </section>
            </section>
          ))
        }
      </div>
    </div>
  </section>
</SiteLayout>

<script>
  import Reveal from "reveal.js";

  function initDeck() {
    const element = document.querySelector<HTMLElement>("#projects-deck");
    if (!element || element.dataset.bound === "true") return;
    element.dataset.bound = "true";

    const deck = new Reveal(element, {
      embedded: true,
      // Keyboard binds once the deck has focus (click/tab into it); the
      // native arrows and touch always work.
      keyboardCondition: "focused",
      hash: false,
      // Navigation & UI indicators
      controls: true,
      controlsTutorial: true, // pulses the ↓ arrow when a slide has children
      controlsLayout: "bottom-right",
      controlsBackArrows: "visible",
      progress: true,
      slideNumber: "h/v",
      overview: true,
      touch: true,
      // 2D grid: left/right = projects, down = that project's case study
      navigationMode: "grid",
      transition: "slide",
      backgroundTransition: "none",
      width: 1280,
      height: 800,
      margin: 0.08,
    });
    deck.initialize();
  }

  initDeck();
  document.addEventListener("astro:after-swap", initDeck);
</script>

<style is:global>
  /* ------------------------------------------------------------------
     Minimal reveal.js theming. Only targets DOM that reveal.js *generates*
     (and therefore can't carry Tailwind classes): the .reveal root, the
     progress bar, the arrow controls, and the slide-number badge — plus the
     shared heading typography. Everything else is Tailwind in the markup.
     Colors come from the --nb-* tokens in starwind.css.
     ------------------------------------------------------------------ */
  #projects-deck.reveal {
    /* Height must live here, not in a Tailwind utility: reveal adds the
       reveal-viewport class on init, and reveal.css's unlayered
       .reveal-viewport { height: 100% } beats anything in @layer utilities.
       The ID selector out-specifies it. */
    height: 100svh;
    font-size: 30px;
    font-weight: 600;
    line-height: 1.75;
    color: var(--nb-text);
    background: var(--nb-base);
  }
  #projects-deck h1,
  #projects-deck h2,
  #projects-deck h3 {
    color: var(--nb-text);
    text-transform: uppercase;
    font-weight: 900;
    letter-spacing: -0.01em;
    margin: 0 0 24px;
  }
  #projects-deck h1 {
    font-size: clamp(48px, 8vw, 96px);
    line-height: 0.95;
    text-shadow: 6px 6px 0 var(--nb-title-shadow);
  }
  #projects-deck h2 {
    font-size: 48px;
    line-height: 1.05;
  }
  #projects-deck .tagline {
    font-size: 34px;
    font-weight: 700;
    margin-bottom: 8px;
  }
  #projects-deck :focus-visible {
    outline: 4px solid var(--nb-blue);
    outline-offset: 4px;
  }

  /* Progress bar: thick ink track, peach fill, hard edge */
  #projects-deck .progress {
    height: 12px;
    background: var(--nb-surface);
    border-top: 4px solid var(--nb-ink);
    color: var(--nb-peach);
  }
  #projects-deck .progress span {
    background: var(--nb-peach);
    border-right: 4px solid var(--nb-ink);
  }

  /* Native arrows: ink on Latte, peach on Mocha */
  #projects-deck .controls {
    color: var(--nb-ink);
    bottom: 32px;
    right: 32px;
  }
  html[data-theme="dark"] #projects-deck .controls {
    color: var(--nb-peach);
  }

  #projects-deck .slide-number {
    right: auto;
    left: 16px;
    bottom: 24px;
    padding: 4px 10px;
    font-family: inherit;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0.02em;
    color: var(--nb-button-text);
    background: var(--nb-yellow);
    border: 2px solid var(--nb-ink);
    box-shadow: 3px 3px 0 0 var(--nb-ink);
  }
</style>
