---
import { getCollection, render } from "astro:content";
import SiteLayout from "@/layouts/SiteLayout.astro";

const projects = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);
const rendered = await Promise.all(
  projects.map(async (entry) => ({ entry, Content: (await render(entry)).Content })),
);
const description =
  "Deep dives into every project: the challenge, the architecture, and the optimizations.";
const padded = (value: number) => String(value).padStart(2, "0");
---

<SiteLayout title="Projects" description={description}>
  <section class="border-b-4 border-[var(--nb-ink)] bg-[var(--nb-base)] px-4 py-10 md:px-6">
    <div class="mx-auto max-w-7xl">
      <p
        class="mb-4 inline-flex border-4 border-[var(--nb-ink)] bg-[var(--nb-teal)] px-3 py-2 text-sm font-black text-[var(--nb-button-text)] uppercase shadow-[4px_4px_0_0_var(--nb-ink)]"
      >
        The deep dive
      </p>
      <h1 class="text-5xl font-black uppercase md:text-7xl">Projects</h1>
      <p class="mt-4 max-w-3xl text-lg font-bold text-[var(--nb-muted)]">
        Every experiment with its rationale: the challenge, the engineering decisions, and the
        optimizations. One project per screen &mdash; scroll to flip through the gallery.
      </p>
    </div>
  </section>

  <section class="relative border-b-4 border-[var(--nb-ink)] bg-[var(--nb-surface)]">
    <div data-gallery class="h-svh snap-y snap-mandatory overflow-y-auto">
      {
        rendered.map(({ entry, Content }, index) => (
          <div
            data-gallery-card
            data-index={index}
            class="flex h-svh snap-start items-center justify-center px-4 py-6 md:px-6"
          >
            <article
              data-gallery-content
              class="nb-card max-h-[86svh] w-full max-w-3xl overflow-y-auto p-6 md:p-8"
            >
              <header class="border-b-4 border-[var(--nb-ink)] pb-5">
                <p class="text-xs font-black text-[var(--nb-muted)] uppercase">
                  Project {padded(index + 1)}
                </p>
                <h3 class="mt-1 text-3xl font-black uppercase md:text-4xl">{entry.data.title}</h3>
                <p class="mt-2 text-base leading-7 font-bold text-[var(--nb-muted)]">
                  {entry.data.valueProp}
                </p>
                <div class="mt-4 flex flex-wrap gap-2">
                  <a class="nb-action px-4 py-3 text-sm" href={entry.data.liveUrl}>
                    Launch Live App
                  </a>
                  {entry.data.repoUrl ? (
                    <a
                      class="nb-action bg-[var(--nb-base)] px-4 py-3 text-sm text-[var(--nb-text)]"
                      href={entry.data.repoUrl}
                    >
                      GitHub Repository
                    </a>
                  ) : (
                    <span
                      class="cursor-not-allowed border-4 border-[var(--nb-ink)] bg-[var(--nb-surface)] px-4 py-3 text-sm font-black text-[var(--nb-muted)] uppercase opacity-70"
                      title="Repository link pending"
                    >
                      [GITHUB_REPO_URL]
                    </span>
                  )}
                </div>
                <div class="mt-4 flex flex-wrap gap-1.5">
                  {entry.data.tech.map((item) => (
                    <span class="border-2 border-[var(--nb-ink)] bg-[var(--nb-yellow)] px-1.5 py-0.5 text-[10px] font-black text-[var(--nb-button-text)] uppercase">
                      {item}
                    </span>
                  ))}
                </div>
              </header>
              <div class="nb-prose mt-2 text-sm">
                <Content />
              </div>
            </article>
          </div>
        ))
      }
    </div>

    <div
      data-gallery-indicator
      class="absolute top-1/2 right-3 z-10 flex -translate-y-1/2 flex-col items-center gap-3 md:right-6"
    >
      <p
        data-gallery-counter
        class="border-2 border-[var(--nb-ink)] bg-[var(--nb-base)] px-2 py-1 text-xs font-black tabular-nums shadow-[3px_3px_0_0_var(--nb-ink)]"
      >
        01&thinsp;/&thinsp;{padded(projects.length)}
      </p>
      <div class="flex flex-col gap-2">
        {
          rendered.map(({ entry }, index) => (
            <button
              type="button"
              data-gallery-dot
              data-index={index}
              aria-label={`Go to project ${index + 1}: ${entry.data.title}`}
              class="size-4 border-2 border-[var(--nb-ink)] bg-[var(--nb-base)] transition-colors"
            />
          ))
        }
      </div>
    </div>
  </section>
</SiteLayout>

<script>
  function initGallery() {
    const gallery = document.querySelector<HTMLElement>("[data-gallery]");
    if (!gallery || gallery.dataset.bound === "true") return;
    gallery.dataset.bound = "true";

    const cards = [...gallery.querySelectorAll<HTMLElement>("[data-gallery-card]")];
    const counter = document.querySelector<HTMLElement>("[data-gallery-counter]");
    const dots = [...document.querySelectorAll<HTMLElement>("[data-gallery-dot]")];
    const total = String(cards.length).padStart(2, "0");
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    function activate(index: number) {
      if (counter) {
        counter.textContent = `${String(index + 1).padStart(2, "0")} / ${total}`;
      }
      dots.forEach((dot, dotIndex) => {
        dot.classList.toggle("bg-[var(--nb-peach)]", dotIndex === index);
        dot.classList.toggle("bg-[var(--nb-base)]", dotIndex !== index);
      });
      cards.forEach((card, cardIndex) => {
        const content = card.querySelector<HTMLElement>("[data-gallery-content]");
        if (!content || reducedMotion) return;
        // Re-adding the rombo preset replays the entrance when a card
        // becomes the active gallery slide.
        if (cardIndex === index) content.classList.add("motion-preset-slide-down");
        else content.classList.remove("motion-preset-slide-down");
      });
    }

    const observer = new IntersectionObserver(
      (observed) => {
        for (const entry of observed) {
          if (!entry.isIntersecting) continue;
          activate(Number((entry.target as HTMLElement).dataset.index));
        }
      },
      { root: gallery, threshold: 0.6 },
    );
    cards.forEach((card) => observer.observe(card));

    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        cards[Number(dot.dataset.index)]?.scrollIntoView({
          behavior: reducedMotion ? "auto" : "smooth",
        });
      });
    });

    activate(0);
  }

  initGallery();
  document.addEventListener("astro:after-swap", initGallery);
</script>
