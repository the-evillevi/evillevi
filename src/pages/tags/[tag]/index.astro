---
import PostCard from "@/components/blog/PostCard.astro";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { getAllTags, getBlogPosts, getDocsEntries } from "@/utils/content";

export async function getStaticPaths() {
  const entries = [...(await getBlogPosts()), ...(await getDocsEntries())];
  return getAllTags(entries).map(({ tag }) => ({
    params: { tag },
    props: { tag, entries: entries.filter((entry) => entry.data.tags.includes(tag)) },
  }));
}

const { tag, entries } = Astro.props;
---

<SiteLayout title={`#${tag}`} description={`Entries tagged ${tag}`}>
  <section class="mx-auto max-w-7xl px-4 py-10 md:px-6">
    <h1 class="mb-8 text-6xl font-black uppercase md:text-8xl">#{tag}</h1>
    <div class="grid gap-5 md:grid-cols-2">
      {entries.map((entry) => <PostCard {entry} />)}
    </div>
  </section>
</SiteLayout>
