---
import SiteLayout from "@/layouts/SiteLayout.astro";
import { getAllTags, getBlogPosts, getDocsEntries } from "@/utils/content";

const entries = [...(await getBlogPosts()), ...(await getDocsEntries())];
const tags = getAllTags(entries);
---

<SiteLayout title="Tags" description="Browse notes by tag">
  <section class="mx-auto max-w-7xl px-4 py-10 md:px-6">
    <h1 class="mb-8 text-6xl font-black uppercase md:text-8xl">Tags</h1>
    <div class="flex flex-wrap gap-3">
      {
        tags.map(({ tag, count }) => (
          <a class="nb-action bg-[var(--nb-yellow)] px-4 py-3" href={`/tags/${tag}`}>
            #{tag} {count}
          </a>
        ))
      }
    </div>
  </section>
</SiteLayout>
