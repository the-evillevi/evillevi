---
import PostCard from "@/components/blog/PostCard.astro";
import SearchDialog from "@/components/blog/SearchDialog.astro";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { siteConfig } from "@/site.config";
import { getAllTags, getBlogPosts, getDocsEntries } from "@/utils/content";

const posts = await getBlogPosts();
const docs = await getDocsEntries();
const tags = getAllTags([...posts, ...docs]).slice(0, 10);
---

<SiteLayout>
  <section class="border-b-4 border-[var(--nb-ink)] bg-[var(--nb-base)] px-4 py-12 md:px-6 md:py-20">
    <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[1.2fr_0.8fr] lg:items-end">
      <div>
        <p class="mb-4 inline-flex border-4 border-[var(--nb-ink)] bg-[var(--nb-green)] px-3 py-2 text-sm font-black text-[var(--nb-button-text)] uppercase shadow-[4px_4px_0_0_var(--nb-ink)]">
          Personal knowledge base
        </p>
        <h1 class="max-w-5xl text-6xl leading-[0.92] font-black uppercase md:text-8xl">
          Notes with sharp edges and visible links.
        </h1>
        <p class="mt-6 max-w-3xl text-xl font-bold text-[var(--nb-muted)]">
          {siteConfig.description}
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a class="nb-action px-5 py-4" href="/blog">Read blog</a>
          <a class="nb-action bg-[var(--nb-blue)] px-5 py-4" href="/docs">Open docs</a>
        </div>
      </div>
      <div class="nb-shadow grid gap-4 border-4 border-[var(--nb-ink)] bg-[var(--nb-surface)] p-5">
        <p class="text-sm font-black uppercase text-[var(--nb-peach)]">Garden stats</p>
        <div class="grid grid-cols-3 gap-3">
          <div class="border-4 border-[var(--nb-ink)] bg-[var(--nb-base)] p-3 text-center">
            <p class="text-4xl font-black">{posts.length}</p>
            <p class="text-xs font-black uppercase">Posts</p>
          </div>
          <div class="border-4 border-[var(--nb-ink)] bg-[var(--nb-base)] p-3 text-center">
            <p class="text-4xl font-black">{docs.length}</p>
            <p class="text-xs font-black uppercase">Docs</p>
          </div>
          <div class="border-4 border-[var(--nb-ink)] bg-[var(--nb-base)] p-3 text-center">
            <p class="text-4xl font-black">{tags.length}</p>
            <p class="text-xs font-black uppercase">Tags</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto grid max-w-7xl gap-8 px-4 py-10 md:px-6 lg:grid-cols-[minmax(0,1fr)_360px]">
    <div>
      <div class="mb-5 flex items-end justify-between gap-4">
        <h2 class="text-4xl font-black uppercase">Recent posts</h2>
        <a class="font-black uppercase underline" href="/blog">All posts</a>
      </div>
      <div class="grid gap-5 md:grid-cols-2">
        {posts.slice(0, 4).map((entry) => <PostCard {entry} />)}
      </div>
    </div>

    <aside class="grid h-fit gap-5">
      <SearchDialog />
      <section class="nb-panel p-4">
        <h2 class="mb-3 text-sm font-black uppercase">Tags</h2>
        <div class="flex flex-wrap gap-2">
          {
            tags.map(({ tag, count }) => (
              <a
                class="border-2 border-[var(--nb-ink)] bg-[var(--nb-yellow)] px-2 py-1 text-xs font-black text-[var(--nb-button-text)] uppercase"
                href={`/tags/${tag}`}
              >
                #{tag} {count}
              </a>
            ))
          }
        </div>
      </section>
    </aside>
  </section>
</SiteLayout>
